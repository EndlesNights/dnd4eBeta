  "system": {
    "description": {
      "value": "<p><strong>Ability Score Bonuses:</strong></p>\n<ul>\n<li>+2 to one ability score of your choice</li>\n</ul>\n<p><strong>Character Size:&nbsp;</strong>Medium</p>\n<p><strong>Base Speed:</strong>&nbsp;6</p>\n<p><strong>Known Languages:</strong></p>\n<ul>\n<li>Common</li>\n<li>One other</li>\n</ul>\n<p><strong>Bonus At-Will Power:</strong> You know one extra at-will power from your class.</p>\n<p><strong>Bonus Feat:</strong> You gain a bonus feat at 1st level. You must meet the feat&rsquo;s prerequisites.</p>\n<p><strong>Bonus Skill:</strong> You gain training in one additional skill from your class skill list.</p>\n<p><strong>Human Defense Bonuses:</strong></p>\n<ul>\n<li>+1 Fortitude</li>\n<li>+1 Reflex</li>\n<li>+1 Will</li>\n</ul>\n<p><strong>Average Height:</strong> 5&acute; 6˝ to 6&acute; 2˝</p>\n<p><strong>Average Weight:</strong> 135&ndash;220 lb.</p>",
