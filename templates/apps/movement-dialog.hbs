		<legend>{{localize "DND4E.Movement.Special"}}</legend>
		<div class="form-group base" data-movement="burrow">
			<span class="move-value" data-tooltip="{{localize 'DND4E.MovementSpeedBurrowing'}}"><strong>{{system.movement.burrow.value}} {{localize 'DND4E.Movement.Unit'}}</strong> {{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Burrow')}}:</span>
			<input type="text" name="system.movement.burrow.formula" value="{{system.movement.burrow.formula}}" data-tooltip="{{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Burrow')}}" onClick="this.select();" placeholder="0"/>
			<a class="move-bonus" data-action="movementBonusClicked" data-target="system.details" data-tooltip="{{localize 'DND4E.Movement.Bonus' mode=(localize 'DND4E.Movement.Burrow')}}">{{localize 'DND4E.Bonus'}}: {{system.movement.burrow.bonusValue}}</a>
