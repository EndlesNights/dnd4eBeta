<div id="movement-dialog" class="dialogue-content" onsubmit="event.preventDefault();">
	<p>{{localize 'DND4EUI.SpeedConfigTip' penalty=system.movement.base.armour}}</p>

	<fieldset>
		<legend>{{localize "DND4E.Movement.Standard"}}</legend>
		
		<div class="form-group base" data-movement="base">
			<span class="move-value"><strong>{{system.movement.base.value}} {{localize 'DND4E.Movement.Unit'}}</strong> {{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Base')}}:</span>
			<input type="text" name="system.movement.base.base" value="{{system.movement.base.base}}" data-tooltip="{{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Base')}}" data-dtype="Number" onClick="this.select();" placeholder="0"/>
			<a class="move-bonus" data-action="movementBonusClicked" data-target="system.details" data-tooltip="{{localize 'DND4E.Movement.Bonus' mode=(localize 'DND4E.Movement.Base')}}">{{localize 'DND4E.Bonus'}}: {{system.movement.base.bonusValue}}</a>
			<span class="temp-label">{{localize 'DND4E.Temp'}}:</span>
			<input class="temp-value" type="text" name="system.movement.base.temp" value="{{system.movement.base.temp}}" data-tooltip="{{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Base')}}" data-dtype="Number" onClick="this.select();" placeholder="0"/>
		</div>
		
		<div class="form-group base" data-movement="walk">
			<span class="move-value" data-tooltip="{{localize 'DND4E.MovementSpeedWalking'}}"><strong>{{system.movement.walk.value}} {{localize 'DND4E.Movement.Unit'}}</strong> {{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Walk')}}:</span>
			<input type="text" name="system.movement.walk.formula" value="{{system.movement.walk.formula}}" data-tooltip="{{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Walk')}}" onClick="this.select();" placeholder="0"/>
			<a class="move-bonus" data-action="movementBonusClicked" data-target="system.details" data-tooltip="{{localize 'DND4E.Movement.Bonus' mode=(localize 'DND4E.Movement.Walk')}}">{{localize 'DND4E.Bonus'}}: {{system.movement.walk.bonusValue}}</a>
			<span class="temp-label">{{localize 'DND4E.Temp'}}:</span>
			<input class="temp-value" type="text" name="system.movement.walk.temp" value="{{system.movement.walk.temp}}" data-tooltip="{{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Walk')}}" data-dtype="Number" onClick="this.select();" placeholder="0"/>
		</div>

		<div class="form-group base"  data-movement="run">
			<span class="move-value" data-tooltip="{{localize 'DND4E.MovementSpeedRunning'}}"><strong>{{numberFormat system.movement.run.value
            sign=true}} {{localize 'DND4E.Movement.Unit'}}</strong> {{localize 'DND4E.Movement.RunBonus'}}:</span>
			<input type="text" name="system.movement.run.formula" value="{{system.movement.run.formula}}" data-tooltip="{{localize 'DND4E.Movement.RunBonus'}}" onClick="this.select();" placeholder="0"/>
			<a class="move-bonus" data-action="movementBonusClicked" data-target="system.details" data-tooltip="{{localize 'DND4E.Movement.Bonus' mode=(localize 'DND4E.Movement.RunBonus')}}">{{localize 'DND4E.Bonus'}}: {{system.movement.run.bonusValue}}</a>
			<span class="temp-label">{{localize 'DND4E.Temp'}}:</span>
			<input type="text" class="temp-value" name="system.movement.run.temp" value="{{system.movement.run.temp}}" data-tooltip="{{localize 'DND4E.Movement.RunBonus'}}" data-dtype="Number" onClick="this.select();" placeholder="0"/>
		</div>

		<div class="form-group base"  data-movement="charge">
			<span class="move-value" data-tooltip="Charge Movement Speed"><strong>{{system.movement.charge.value}} {{localize 'DND4E.Movement.Unit'}}</strong> {{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Charge')}}:</span>
			<input type="text" name="system.movement.charge.formula" value="{{system.movement.charge.formula}}" data-tooltip="{{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Charge')}}" onClick="this.select();" placeholder="0"/>
			<a class="move-bonus" data-action="movementBonusClicked" data-target="system.details" data-tooltip="{{localize 'DND4E.Movement.Bonus' mode=(localize 'DND4E.Movement.Charge')}}">{{localize 'DND4E.Bonus'}}: {{system.movement.charge.bonusValue}}</a>
			<span class="temp-label">{{localize 'DND4E.Temp'}}:</span>
			<input type="text" class="temp-value" name="system.movement.charge.temp" value="{{system.movement.charge.temp}}" data-tooltip="{{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Charge')}}" data-dtype="Number" onClick="this.select();" placeholder="0"/>
		</div>

		<div class="form-group base" data-movement="shift">
			<span class="move-value" data-tooltip="{{localize 'DND4E.MovementSpeedShifting'}}"><strong>{{system.movement.shift.value}} {{localize 'DND4E.Movement.Unit'}}</strong> {{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Shift')}}:</span>
			<input type="text" name="system.movement.shift.formula" value="{{system.movement.shift.formula}}" data-tooltip="{{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Shift')}}" onClick="this.select();" placeholder="0"/>
			<a class="move-bonus" data-action="movementBonusClicked" data-target="system.details" data-tooltip="{{localize 'DND4E.Movement.Bonus' mode=(localize 'DND4E.Movement.Shift')}}">{{localize 'DND4E.Bonus'}}: {{system.movement.shift.bonusValue}}</a>
			<span class="temp-label">{{localize 'DND4E.Temp'}}:</span>
			<input type="text" class="temp-value" name="system.movement.shift.temp" value="{{system.movement.shift.temp}}" data-tooltip="{{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Shift')}}" data-dtype="Number" onClick="this.select();" placeholder="0"/>
		</div>
	</fieldset>

