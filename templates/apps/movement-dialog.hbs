			<a class="move-bonus" data-action="movementBonusClicked" data-target="system.details" data-tooltip="{{localize 'DND4E.Movement.Bonus' mode=(localize 'DND4E.Movement.Climb')}}">{{localize 'DND4E.Bonus'}}: {{system.movement.climb.bonusValue}}</a>
			<span class="temp-label">{{localize 'DND4E.Temp'}}:</span>
			<input type="text" class="temp-value" name="system.movement.climb.temp" value="{{system.movement.climb.temp}}" data-tooltip="{{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Climb')}}" data-dtype="Number" onClick="this.select();" placeholder="0"/>
		</div>

		<div class="form-group base" data-movement="fly">
			<span class="move-value" data-tooltip="{{localize 'DND4E.MovementSpeedFlying'}}"><strong>{{system.movement.fly.value}} {{localize 'DND4E.Movement.Unit'}}</strong> {{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Fly')}}:</span>
			<input type="text" name="system.movement.fly.formula" value="{{system.movement.fly.formula}}" data-tooltip="{{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Fly')}}" onClick="this.select();" placeholder="0"/>
			<a class="move-bonus" data-action="movementBonusClicked" data-target="system.details" data-tooltip="{{localize 'DND4E.Movement.Bonus' mode=(localize 'DND4E.Movement.Fly')}}">{{localize 'DND4E.Bonus'}}: {{system.movement.fly.bonusValue}}</a>
			<span class="temp-label">{{localize 'DND4E.Temp'}}:</span>
			<input type="text" class="temp-value" name="system.movement.fly.temp" value="{{system.movement.fly.temp}}" data-tooltip="{{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Fly')}}" data-dtype="Number" onClick="this.select();" placeholder="0"/>
		</div>

		<div class="form-group base" data-movement="swim">
			<span class="move-value" data-tooltip="{{localize 'DND4E.MovementSpeedSwimming'}}"><strong>{{system.movement.swim.value}} {{localize 'DND4E.Movement.Unit'}}</strong> {{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Swim')}}:</span>
			<input type="text" name="system.movement.swim.formula" value="{{system.movement.swim.formula}}" data-tooltip="{{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Swim')}}" onClick="this.select();" placeholder="0"/>
			<a class="move-bonus" data-action="movementBonusClicked" data-target="system.details" data-tooltip="{{localize 'DND4E.Movement.Bonus' mode=(localize 'DND4E.Movement.Swim')}}">{{localize 'DND4E.Bonus'}}: {{system.movement.swim.bonusValue}}</a>
			<span class="temp-label">{{localize 'DND4E.Temp'}}:</span>
			<input type="text" class="temp-value" name="system.movement.swim.temp" value="{{system.movement.swim.temp}}" data-tooltip="{{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Swim')}}" data-dtype="Number" onClick="this.select();" placeholder="0"/>
		</div>

		<div class="form-group base" data-movement="teleport">
			<span class="move-value" data-tooltip="{{localize 'DND4E.MovementSpeedTeleporting'}}"><strong>{{system.movement.teleport.value}} {{localize 'DND4E.Movement.Unit'}}</strong> {{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Teleport')}}:</span>
			<input type="text" name="system.movement.teleport.formula" value="{{system.movement.teleport.formula}}" data-tooltip="{{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Teleport')}}" onClick="this.select();" placeholder="0"/>
			<a class="move-bonus" data-action="movementBonusClicked" data-target="system.details" data-tooltip="{{localize 'DND4E.Movement.Bonus' mode=(localize 'DND4E.Movement.Teleport')}}">{{localize 'DND4E.Bonus'}}: {{system.movement.teleport.bonusValue}}</a>
			<span class="temp-label">{{localize 'DND4E.Temp'}}:</span>
			<input type="text" class="temp-value" name="system.movement.teleport.temp" value="{{system.movement.teleport.temp}}" data-tooltip="{{localize 'DND4E.Movement.SpeedType' mode=(localize 'DND4E.Movement.Teleport')}}" data-dtype="Number" onClick="this.select();" placeholder="0"/>
