		<div class="form-group vertical">
			<label>{{ localize "DND4E.Other" }}</label>
			<input type="text" name="system.movement.custom" value="{{system.movement.custom}}" data-dtype="String"/>
		</div>
	</fieldset>
	
	<fieldset class="form-group vertical">
		<legend>{{localize "DND4E.IgnoredDifficultTerrain"}}</legend>
		<multi-select class="inline" name="system.movement.ignoredDifficultTerrain">
			{{selectOptions config.ignoredDifficultTerrainTypes selected=system.movement.ignoredDifficultTerrain}}
		</multi-select>
	</fieldset>
	
	<div class="form-group vertical">
		<label>{{localize 'DND4E.Notes'}}</label>
		<textarea type="text" name="system.movement.notes" value="{{system.movement.notes}}" data-dtype="String" placeholder="{{localize 'DND4E.Notes'}}" contentEditable>{{system.movement.notes}}</textarea>
	</div>
	
</div>