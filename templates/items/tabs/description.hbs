<section class="tab flexrow {{tab.id}}{{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="{{tab.id}}">

  <div class="item-properties">
    {{#if isPhysical}}
    <div class="form-group">
      <label>{{ localize 'DND4E.Quantity' }}</label>
      <input type="text" name="system.quantity" value="{{system.quantity}}" data-dtype="Number">
    </div>

    <div class="form-group">
      <label>{{ localize 'DND4E.Weight' }} <span class="unit">({{ localize 'DND4E.AbbreviationLbs' }})</span></label>
      <input type="text" name="system.weight" value="{{system.weight}}" data-dtype="Number">
    </div>

    <div class="form-group">
      <label>{{ localize 'DND4E.Price' }} <span class="unit">({{ localize 'DND4E.GP' }})</span></label>
      <input type="text" name="system.price" value="{{system.price}}" data-dtype="Number">
    </div>
    {{/if}}
	
    {{#if (eq this.itemType "ritual")}}
    <div class="form-group">
      <label>{{ localize 'DND4E.Price' }} <span class="unit">({{ localize 'DND4E.GP' }})</span></label>
      <input type="text" name="system.market" value="{{system.market}}" data-dtype="Number">
    </div>
	{{/if}}
	
	{{#unless (eq this.itemType "power")}}{{#unless (eq this.itemType "feature")}}<hr />{{/unless}}{{/unless}}

    <ul class="properties-list tags">
      {{#each itemProperties}}
      {{#if this.label}}
      {{{this.label}}}
      {{else}}
      {{{this}}}
      {{/if}}
      {{/each}}
    </ul>
  </div>

  <section class="description-main scrollable">
    <div class="multi-editor-wrapper">
      <prose-mirror class="main-description{{#if system.description.value}} has-content{{/if}}" toggled name="system.description.value" {{disabled (not editable)}} value="{{system.description.value}}">
        {{#unless system.description.value}}
        <label>{{localize 'DND4E.Sheet.Description'}}</label>
        {{/unless}}
        {{{descriptionHTML}}}
      </prose-mirror>
      {{#if userInfo.isGM}}
      <prose-mirror class="gm-notes{{#if system.description.gm}} has-content{{/if}}" toggled name="system.description.gm" {{disabled (not editable)}} value="{{system.description.gm}}">
        {{#unless system.description.gm}}
        <label>{{localize 'DND4E.GMNotesAdd'}}</label>
        {{/unless}}
        {{{descriptionHTMLGM}}}
      </prose-mirror>
      {{/if}}
    </div>
  </section>
</section>
